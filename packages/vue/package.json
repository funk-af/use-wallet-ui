{
  "name": "@txnlab/use-wallet-ui-vue",
  "version": "1.0.0",
  "description": "Vue components for use-wallet UI",
  "type": "module",
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./plugins/export-key": {
      "import": {
        "types": "./dist/types/plugins/export-key/index.d.ts",
        "default": "./dist/esm/plugins/export-key.js"
      },
      "require": {
        "types": "./dist/types/plugins/export-key/index.d.cts",
        "default": "./dist/cjs/plugins/export-key.cjs"
      }
    },
    "./dist/style.css": "./dist/style.css",
    "./theme.css": "./src/theme.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/theme.css",
    "README.md"
  ],
  "keywords": [
    "algorand",
    "wallet",
    "use-wallet",
    "vue",
    "ui"
  ],
  "author": "TxnLab Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TxnLab/use-wallet-ui.git"
  },
  "bugs": {
    "url": "https://github.com/TxnLab/use-wallet-ui/issues"
  },
  "homepage": "https://github.com/TxnLab/use-wallet-ui#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm generate:css && vite build && publint --strict",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"**/*.{js,ts}\"",
    "format": "prettier --write .",
    "typecheck": "vue-tsc --noEmit",
    "generate:css": "npx @tailwindcss/cli -c ./tailwind.config.js -i ./src/input.css -o ./dist/style.css && node ./scripts/post-process-css.js"
  },
  "peerDependencies": {
    "@txnlab/use-wallet-vue": "^4.6.0",
    "vue": "^3.3"
  },
  "dependencies": {
    "@floating-ui/vue": "1.1.6",
    "@headlessui/vue": "1.7.23",
    "@tanstack/vue-query": "5.96.2",
    "@txnlab/utils-ts": "0.1.0",
    "clsx": "2.1.1",
    "tailwind-merge": "3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.2.2",
    "@types/node": "22.15.3",
    "@vitejs/plugin-vue": "5.2.4",
    "@vue/test-utils": "2.4.6",
    "@vitest/coverage-v8": "3.2.4",
    "algosdk": "3.5.2",
    "publint": "0.3.18",
    "tailwindcss": "4.2.2",
    "tsx": "4.21.0",
    "vite": "6.4.2",
    "vite-plugin-dts": "4.5.4",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.2.4",
    "vue": "3.5.13",
    "vue-tsc": "2.2.10"
  }
}
